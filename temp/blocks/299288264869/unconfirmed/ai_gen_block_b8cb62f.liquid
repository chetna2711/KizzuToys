{% doc %}
  @prompt
    Create an A+ style product listing section for a Shopify product page that includes: a rich brand story banner with full-width lifestyle image and overlay text, a feature highlights grid with icons and short descriptions, a product comparison table, and a "Why Choose Us" section with trust badges. The design should be visually rich, mobile-friendly, and suitable for a toy store.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-aplus-listing-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-aplus-brand-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.banner_height }}px;
    overflow: hidden;
    margin-bottom: 40px;
  }

  .ai-aplus-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.banner_height }}px;
    object-fit: cover;
  }

  .ai-aplus-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.banner_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-aplus-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 400px;
  }

  .ai-aplus-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }}),
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }})
    );
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-aplus-banner-content-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.banner_text_color }};
    max-width: 800px;
  }

  .ai-aplus-banner-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.banner_title_size }}px;
    font-weight: 700;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-aplus-banner-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.banner_subtitle_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-aplus-features-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.features_bg_color }};
    margin-bottom: 40px;
  }

  .ai-aplus-features-title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.section_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.features_text_color }};
    margin: 0 0 40px;
  }

  .ai-aplus-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-aplus-feature-item-{{ ai_gen_id }} {
    text-align: center;
    padding: 20px;
  }

  .ai-aplus-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 16px;
    background-color: {{ block.settings.icon_bg_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.icon_size | times: 0.5 }}px;
  }

  .ai-aplus-feature-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.features_text_color }};
    margin: 0 0 8px;
  }

  .ai-aplus-feature-desc-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.features_text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-aplus-comparison-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.comparison_bg_color }};
    margin-bottom: 40px;
  }

  .ai-aplus-comparison-title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.section_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.comparison_text_color }};
    margin: 0 0 40px;
  }

  .ai-aplus-comparison-table-wrapper-{{ ai_gen_id }} {
    max-width: 1000px;
    margin: 0 auto;
    overflow-x: auto;
  }

  .ai-aplus-comparison-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_bg_color }};
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-aplus-comparison-table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.table_header_bg }};
    color: {{ block.settings.table_header_text }};
    padding: 16px;
    text-align: left;
    font-weight: 600;
    font-size: 16px;
  }

  .ai-aplus-comparison-table-{{ ai_gen_id }} td {
    padding: 16px;
    border-bottom: 1px solid {{ block.settings.table_border_color }};
    color: {{ block.settings.comparison_text_color }};
    font-size: 14px;
  }

  .ai-aplus-comparison-table-{{ ai_gen_id }} tr:last-child td {
    border-bottom: none;
  }

  .ai-aplus-comparison-checkmark-{{ ai_gen_id }} {
    color: {{ block.settings.checkmark_color }};
    font-size: 20px;
    font-weight: 700;
  }

  .ai-aplus-comparison-cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
    font-size: 20px;
    font-weight: 700;
  }

  .ai-aplus-trust-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.trust_bg_color }};
  }

  .ai-aplus-trust-title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.section_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.trust_text_color }};
    margin: 0 0 40px;
  }

  .ai-aplus-trust-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .ai-aplus-trust-badge-{{ ai_gen_id }} {
    text-align: center;
    padding: 24px;
    background-color: {{ block.settings.badge_bg_color }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-aplus-trust-icon-{{ ai_gen_id }} {
    width: {{ block.settings.trust_icon_size }}px;
    height: {{ block.settings.trust_icon_size }}px;
    margin: 0 auto 16px;
    background-color: {{ block.settings.trust_icon_bg }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.trust_icon_size | times: 0.5 }}px;
  }

  .ai-aplus-trust-badge-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.trust_text_color }};
    margin: 0 0 8px;
  }

  .ai-aplus-trust-badge-desc-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.trust_text_color }};
    line-height: 1.4;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-aplus-banner-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.banner_title_size | times: 0.7 }}px;
    }

    .ai-aplus-banner-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.banner_subtitle_size | times: 0.8 }}px;
    }

    .ai-aplus-features-title-{{ ai_gen_id }},
    .ai-aplus-comparison-title-{{ ai_gen_id }},
    .ai-aplus-trust-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.section_title_size | times: 0.8 }}px;
    }

    .ai-aplus-features-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-aplus-trust-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-aplus-comparison-table-{{ ai_gen_id }} {
      font-size: 12px;
    }

    .ai-aplus-comparison-table-{{ ai_gen_id }} th,
    .ai-aplus-comparison-table-{{ ai_gen_id }} td {
      padding: 12px 8px;
    }
  }
{% endstyle %}

<aplus-listing-{{ ai_gen_id }} class="ai-aplus-listing-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-aplus-brand-banner-{{ ai_gen_id }}">
    {% if block.settings.banner_image %}
      <img
        src="{{ block.settings.banner_image | image_url: width: 2000 }}"
        alt="{{ block.settings.banner_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.banner_image.width }}"
        height="{{ block.settings.banner_image.height }}"
        class="ai-aplus-banner-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-aplus-banner-placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle' | placeholder_svg_tag }}
      </div>
    {% endif %}
    <div class="ai-aplus-banner-overlay-{{ ai_gen_id }}">
      <div class="ai-aplus-banner-content-{{ ai_gen_id }}">
        {% if block.settings.banner_title != blank %}
          <h2 class="ai-aplus-banner-title-{{ ai_gen_id }}">{{ block.settings.banner_title }}</h2>
        {% endif %}
        {% if block.settings.banner_subtitle != blank %}
          <div class="ai-aplus-banner-subtitle-{{ ai_gen_id }}">{{ block.settings.banner_subtitle }}</div>
        {% endif %}
      </div>
    </div>
  </div>

  {% if block.settings.show_features %}
    <div class="ai-aplus-features-{{ ai_gen_id }}">
      {% if block.settings.features_title != blank %}
        <h3 class="ai-aplus-features-title-{{ ai_gen_id }}">{{ block.settings.features_title }}</h3>
      {% endif %}
      <div class="ai-aplus-features-grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign feature_enabled_key = 'feature_' | append: i | append: '_enabled'
            assign feature_icon_key = 'feature_' | append: i | append: '_icon'
            assign feature_title_key = 'feature_' | append: i | append: '_title'
            assign feature_desc_key = 'feature_' | append: i | append: '_desc'

            assign feature_enabled = block.settings[feature_enabled_key]
            assign feature_icon = block.settings[feature_icon_key]
            assign feature_title = block.settings[feature_title_key]
            assign feature_desc = block.settings[feature_desc_key]
          %}

          {% if feature_enabled %}
            <div class="ai-aplus-feature-item-{{ ai_gen_id }}">
              <div class="ai-aplus-feature-icon-{{ ai_gen_id }}">
                {{ feature_icon }}
              </div>
              {% if feature_title != blank %}
                <h4 class="ai-aplus-feature-title-{{ ai_gen_id }}">{{ feature_title }}</h4>
              {% endif %}
              {% if feature_desc != blank %}
                <p class="ai-aplus-feature-desc-{{ ai_gen_id }}">{{ feature_desc }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_comparison %}
    <div class="ai-aplus-comparison-{{ ai_gen_id }}">
      {% if block.settings.comparison_title != blank %}
        <h3 class="ai-aplus-comparison-title-{{ ai_gen_id }}">{{ block.settings.comparison_title }}</h3>
      {% endif %}
      <div class="ai-aplus-comparison-table-wrapper-{{ ai_gen_id }}">
        <table class="ai-aplus-comparison-table-{{ ai_gen_id }}">
          <thead>
            <tr>
              <th>{{ block.settings.table_col1_header }}</th>
              <th>{{ block.settings.table_col2_header }}</th>
              <th>{{ block.settings.table_col3_header }}</th>
            </tr>
          </thead>
          <tbody>
            {% for i in (1..5) %}
              {% liquid
                assign row_enabled_key = 'row_' | append: i | append: '_enabled'
                assign row_feature_key = 'row_' | append: i | append: '_feature'
                assign row_col2_key = 'row_' | append: i | append: '_col2'
                assign row_col3_key = 'row_' | append: i | append: '_col3'

                assign row_enabled = block.settings[row_enabled_key]
                assign row_feature = block.settings[row_feature_key]
                assign row_col2 = block.settings[row_col2_key]
                assign row_col3 = block.settings[row_col3_key]
              %}

              {% if row_enabled %}
                <tr>
                  <td>{{ row_feature }}</td>
                  <td>
                    {% if row_col2 == 'yes' %}
                      <span class="ai-aplus-comparison-checkmark-{{ ai_gen_id }}">✓</span>
                    {% elsif row_col2 == 'no' %}
                      <span class="ai-aplus-comparison-cross-{{ ai_gen_id }}">✗</span>
                    {% else %}
                      {{ row_col2 }}
                    {% endif %}
                  </td>
                  <td>
                    {% if row_col3 == 'yes' %}
                      <span class="ai-aplus-comparison-checkmark-{{ ai_gen_id }}">✓</span>
                    {% elsif row_col3 == 'no' %}
                      <span class="ai-aplus-comparison-cross-{{ ai_gen_id }}">✗</span>
                    {% else %}
                      {{ row_col3 }}
                    {% endif %}
                  </td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_trust %}
    <div class="ai-aplus-trust-{{ ai_gen_id }}">
      {% if block.settings.trust_title != blank %}
        <h3 class="ai-aplus-trust-title-{{ ai_gen_id }}">{{ block.settings.trust_title }}</h3>
      {% endif %}
      <div class="ai-aplus-trust-grid-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign badge_enabled_key = 'badge_' | append: i | append: '_enabled'
            assign badge_icon_key = 'badge_' | append: i | append: '_icon'
            assign badge_title_key = 'badge_' | append: i | append: '_title'
            assign badge_desc_key = 'badge_' | append: i | append: '_desc'

            assign badge_enabled = block.settings[badge_enabled_key]
            assign badge_icon = block.settings[badge_icon_key]
            assign badge_title = block.settings[badge_title_key]
            assign badge_desc = block.settings[badge_desc_key]
          %}

          {% if badge_enabled %}
            <div class="ai-aplus-trust-badge-{{ ai_gen_id }}">
              <div class="ai-aplus-trust-icon-{{ ai_gen_id }}">
                {{ badge_icon }}
              </div>
              {% if badge_title != blank %}
                <h4 class="ai-aplus-trust-badge-title-{{ ai_gen_id }}">{{ badge_title }}</h4>
              {% endif %}
              {% if badge_desc != blank %}
                <p class="ai-aplus-trust-badge-desc-{{ ai_gen_id }}">{{ badge_desc }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}
</aplus-listing-{{ ai_gen_id }}>

<script>
  (function() {
    class AplusListing{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const tables = this.querySelectorAll('table');
        tables.forEach(table => {
          table.setAttribute('role', 'table');
        });
      }
    }

    customElements.define('aplus-listing-{{ ai_gen_id }}', AplusListing{{ ai_gen_id }});
  })();
</script>

{% schema %}
