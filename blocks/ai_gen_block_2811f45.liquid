    {
      "type": "text",
      "id": "question_1",
      "label": "Question",
      "default": "What is your return policy?"
    },
    {
      "type": "richtext",
      "id": "answer_1",
      "label": "Answer",
      "default": "<p>We offer a 30-day return policy on all unused items in their original packaging. Please contact our customer service team to initiate a return.</p>"
