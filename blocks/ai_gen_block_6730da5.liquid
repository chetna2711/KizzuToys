      "label": "Make phone required",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "company_label",
      "label": "Company field label",
      "default": "Company name"
    },
    {
      "type": "inline_richtext",
      "id": "product_label",
      "label": "Product field label",
      "default": "Product name"
    },
    {
