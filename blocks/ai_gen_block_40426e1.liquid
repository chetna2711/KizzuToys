{% doc %}
  @prompt
    contact details of company
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-details-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-details-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-contact-details-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    font-weight: 600;
  }

  .ai-contact-details-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_spacing }}px;
  }

  .ai-contact-details-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-contact-details-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-contact-details-text-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-contact-details-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: 600;
    margin: 0 0 4px 0;
  }

  .ai-contact-details-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-contact-details-value-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
  }

  .ai-contact-details-value-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-details-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<contact-details-{{ ai_gen_id }}
  class="ai-contact-details-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-contact-details-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-contact-details-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.show_address and block.settings.address != blank %}
      <div class="ai-contact-details-item-{{ ai_gen_id }}">
        <div class="ai-contact-details-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <div class="ai-contact-details-text-{{ ai_gen_id }}">
          <p class="ai-contact-details-label-{{ ai_gen_id }}">{{ block.settings.address_label }}</p>
          <div class="ai-contact-details-value-{{ ai_gen_id }}">{{ block.settings.address }}</div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_phone and block.settings.phone != blank %}
      <div class="ai-contact-details-item-{{ ai_gen_id }}">
        <div class="ai-contact-details-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </div>
        <div class="ai-contact-details-text-{{ ai_gen_id }}">
          <p class="ai-contact-details-label-{{ ai_gen_id }}">{{ block.settings.phone_label }}</p>
          <p class="ai-contact-details-value-{{ ai_gen_id }}">
            <a href="tel:{{ block.settings.phone | replace: ' ', '' }}">{{ block.settings.phone }}</a>
          </p>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_email and block.settings.email != blank %}
      <div class="ai-contact-details-item-{{ ai_gen_id }}">
        <div class="ai-contact-details-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <div class="ai-contact-details-text-{{ ai_gen_id }}">
          <p class="ai-contact-details-label-{{ ai_gen_id }}">{{ block.settings.email_label }}</p>
          <p class="ai-contact-details-value-{{ ai_gen_id }}">
            <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
          </p>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_hours and block.settings.hours != blank %}
      <div class="ai-contact-details-item-{{ ai_gen_id }}">
        <div class="ai-contact-details-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <div class="ai-contact-details-text-{{ ai_gen_id }}">
          <p class="ai-contact-details-label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</p>
          <div class="ai-contact-details-value-{{ ai_gen_id }}">{{ block.settings.hours }}</div>
        </div>
      </div>
    {% endif %}
  </div>
</contact-details-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactDetails{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('contact-details-{{ ai_gen_id }}', ContactDetails{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contact details",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch"
    },
    {
      "type": "checkbox",
      "id": "show_address",
      "label": "Show address",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "address_label",
      "label": "Address label",
      "default": "Address"
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "Address",
      "default": "<p>123 Main Street<br>City, State 12345<br>India</p>"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "phone_label",
      "label": "Phone label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+91 12345 67890"
    },
    {
      "type": "checkbox",
      "id": "show_email",
      "label": "Show email",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "contact@example.com"
    },
    {
      "type": "checkbox",
      "id": "show_hours",
      "label": "Show business hours",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "hours_label",
      "label": "Hours label",
      "default": "Business hours"
    },
    {
      "type": "richtext",
      "id": "hours",
      "label": "Business hours",
      "default": "<p>Monday - Friday: 9:00 AM - 6:00 PM<br>Saturday: 10:00 AM - 4:00 PM<br>Sunday: Closed</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "value_size",
      "label": "Value size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1f1f21"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label",
      "default": "#e3fc02"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon",
      "default": "#e3fc02"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link",
      "default": "#e3fc02"
    }
  ],
  "presets": [
    {
      "name": "Contact details"
    }
  ]
}
{% endschema %}
