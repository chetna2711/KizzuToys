{% doc %}
  @prompt
    create a review section & add customer reviews in carousel format
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-reviews-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 40px;
  }

  .ai-reviews-carousel__badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 38px;
    padding: 8px 22px;
    margin-bottom: 18px;
    border: 1px solid #e5e9eb;
    border-radius: 999px;
    background: #ffffff;
    color: #008f86;
    box-shadow: 0 4px 14px rgba(8, 20, 40, 0.08);
    font-size: 14px;
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
  }

  .ai-reviews-carousel__badge-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .ai-reviews-carousel__heading-{{ ai_gen_id }} {
    font-size: 36px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 10px;
    font-weight: 900;
  }

  .ai-reviews-carousel__subheading-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-reviews-carousel__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    padding: 0 60px;
  }

  .ai-reviews-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-reviews-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap }}px * ({{ block.settings.cards_per_view | minus: 1 }})) / {{ block.settings.cards_per_view }});
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 30px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-reviews-carousel__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 15px;
  }

  .ai-reviews-carousel__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-reviews-carousel__star-{{ ai_gen_id }}--empty {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-reviews-carousel__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .ai-reviews-carousel__author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .ai-reviews-carousel__avatar-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: {{ block.settings.avatar_background }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-reviews-carousel__avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-reviews-carousel__avatar-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-reviews-carousel__avatar-placeholder-{{ ai_gen_id }} svg {
    width: 30px;
    height: 30px;
    fill: {{ block.settings.text_color }};
    opacity: 0.3;
  }

  .ai-reviews-carousel__author-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-reviews-carousel__author-name-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px;
  }

  .ai-reviews-carousel__author-title-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  .ai-reviews-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease;
  }

  .ai-reviews-carousel__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-reviews-carousel__nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-reviews-carousel__nav-{{ ai_gen_id }}--prev {
    left: 0;
  }

  .ai-reviews-carousel__nav-{{ ai_gen_id }}--next {
    right: 0;
  }

  .ai-reviews-carousel__nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.nav_icon_color }};
  }

  .ai-reviews-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 30px;
  }

  .ai-reviews-carousel__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease;
  }

  .ai-reviews-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-reviews-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px * ({{ block.settings.cards_per_view_tablet | minus: 1 }})) / {{ block.settings.cards_per_view_tablet }});
    }
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-carousel__container-{{ ai_gen_id }} {
      padding: 0 50px;
    }

    .ai-reviews-carousel__card-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-reviews-carousel__nav-{{ ai_gen_id }} {
      width: 35px;
      height: 35px;
    }

    .ai-reviews-carousel__badge-{{ ai_gen_id }} {
      min-height: 34px;
      padding: 7px 18px;
      font-size: 12px;
    }

    .ai-reviews-carousel__heading-{{ ai_gen_id }} {
      font-size: 28px;
    }

    .ai-reviews-carousel__subheading-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<customer-reviews-carousel-{{ ai_gen_id }}
  class="ai-reviews-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-reviews-carousel__header-{{ ai_gen_id }}">
      {% if block.settings.badge_text != blank %}
        <div class="ai-reviews-carousel__badge-{{ ai_gen_id }}">
          <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24">
            <path d="M12 2 14.6 8.2 21.3 8.8 16.2 13.2 17.7 19.8 12 16.3 6.3 19.8 7.8 13.2 2.7 8.8 9.4 8.2 12 2Z"/>
          </svg>
          <span>{{ block.settings.badge_text }}</span>
        </div>
      {% endif %}
      {% if block.settings.heading != blank %}
        <h2 class="ai-reviews-carousel__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-reviews-carousel__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-reviews-carousel__container-{{ ai_gen_id }}">
    <button
      class="ai-reviews-carousel__nav-{{ ai_gen_id }} ai-reviews-carousel__nav-{{ ai_gen_id }}--prev"
      aria-label="Previous review"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
      </svg>
    </button>

    <div class="ai-reviews-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign review_enabled_key = 'review_' | append: i | append: '_enabled'
          assign review_rating_key = 'review_' | append: i | append: '_rating'
          assign review_text_key = 'review_' | append: i | append: '_text'
          assign review_author_key = 'review_' | append: i | append: '_author'
          assign review_title_key = 'review_' | append: i | append: '_title'
          assign review_avatar_key = 'review_' | append: i | append: '_avatar'

          assign review_enabled = block.settings[review_enabled_key]
          assign review_rating = block.settings[review_rating_key]
          assign review_text = block.settings[review_text_key]
          assign review_author = block.settings[review_author_key]
          assign review_title = block.settings[review_title_key]
          assign review_avatar = block.settings[review_avatar_key]
        %}

        {% if review_enabled %}
          <div class="ai-reviews-carousel__card-{{ ai_gen_id }}">
            <div class="ai-reviews-carousel__stars-{{ ai_gen_id }}">
              {% for star in (1..5) %}
                {% if star <= review_rating %}
                  <svg class="ai-reviews-carousel__star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                  </svg>
                {% else %}
                  <svg class="ai-reviews-carousel__star-{{ ai_gen_id }} ai-reviews-carousel__star-{{ ai_gen_id }}--empty" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                  </svg>
                {% endif %}
              {% endfor %}
            </div>

            {% if review_text != blank %}
              <div class="ai-reviews-carousel__text-{{ ai_gen_id }}">{{ review_text }}</div>
            {% endif %}

            <div class="ai-reviews-carousel__author-{{ ai_gen_id }}">
              <div class="ai-reviews-carousel__avatar-{{ ai_gen_id }}">
                {% if review_avatar %}
                  <img
                    src="{{ review_avatar | image_url: width: 100 }}"
                    alt="{{ review_author | escape }}"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                {% else %}
                  <div class="ai-reviews-carousel__avatar-placeholder-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                  </div>
                {% endif %}
              </div>
              <div class="ai-reviews-carousel__author-info-{{ ai_gen_id }}">
                {% if review_author != blank %}
                  <p class="ai-reviews-carousel__author-name-{{ ai_gen_id }}">{{ review_author }}</p>
                {% endif %}
                {% if review_title != blank %}
                  <p class="ai-reviews-carousel__author-title-{{ ai_gen_id }}">{{ review_title }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <button
      class="ai-reviews-carousel__nav-{{ ai_gen_id }} ai-reviews-carousel__nav-{{ ai_gen_id }}--next"
      aria-label="Next review"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
      </svg>
    </button>
  </div>

  <div class="ai-reviews-carousel__dots-{{ ai_gen_id }}"></div>
</customer-reviews-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerReviewsCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.cardsPerView = {{ block.settings.cards_per_view }};
        this.cardsPerViewTablet = {{ block.settings.cards_per_view_tablet }};
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-reviews-carousel__track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-reviews-carousel__card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-reviews-carousel__nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-reviews-carousel__nav-{{ ai_gen_id }}--next');
        this.dotsContainer = this.querySelector('.ai-reviews-carousel__dots-{{ ai_gen_id }}');

        this.updateCardsPerView();
        this.createDots();
        this.updateCarousel();
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.createDots();
          this.updateCarousel();
        });
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.cardsPerView = 1;
        } else if (width <= 989) {
          this.cardsPerView = this.cardsPerViewTablet;
        } else {
          this.cardsPerView = {{ block.settings.cards_per_view }};
        }
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        const totalSlides = Math.ceil(this.cards.length / this.cardsPerView);

        for (let i = 0; i < totalSlides; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-reviews-carousel__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }

        this.dots = this.querySelectorAll('.ai-reviews-carousel__dot-{{ ai_gen_id }}');
      }

      updateCarousel() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * this.cardsPerView * (cardWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= Math.ceil(this.cards.length / this.cardsPerView) - 1;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        if (this.currentIndex < Math.ceil(this.cards.length / this.cardsPerView) - 1) {
          this.currentIndex++;
          this.updateCarousel();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }
    }

    customElements.define('customer-reviews-carousel-{{ ai_gen_id }}', CustomerReviewsCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Customer reviews carousel",
  "tag": null,
  "settings": [
