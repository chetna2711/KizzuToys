{{ 'kizzu-testimonials.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}

<section class="kizzu-testimonials section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width kizzu-testimonials__wrap">
    <header class="kizzu-testimonials__header">
      {% if section.settings.badge_text != blank %}<div class="kizzu-testimonials__badge"><svg aria-hidden="true" viewBox="0 0 20 20"><path d="M10 17.5 8.7 16.3C4.3 12.3 1.5 9.8 1.5 6.7 1.5 4.2 3.5 2.2 6 2.2c1.4 0 2.8.7 3.7 1.8.9-1.1 2.3-1.8 3.7-1.8 2.5 0 4.6 2 4.6 4.5 0 3.1-2.8 5.6-7.2 9.6L10 17.5Z"/></svg>{{ section.settings.badge_text }}</div>{% endif %}
      {% if section.settings.heading != blank %}<h2 class="kizzu-testimonials__heading">{{ section.settings.heading }}{% if section.settings.heading_highlight != blank %} <span class="kizzu-testimonials__heading-accent">{{ section.settings.heading_highlight }}</span>{% endif %}</h2>{% endif %}
      {% if section.settings.description != blank %}<div class="kizzu-testimonials__description rte">{{ section.settings.description }}</div>{% endif %}
    </header>
    <div class="kizzu-testimonials__slider-wrap">
      <button class="kizzu-testimonials__arrow kizzu-testimonials__arrow--prev" type="button" aria-label="Previous testimonials">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M15.4 7.4 14 6l-6 6 6 6 1.4-1.4-4.6-4.6 4.6-4.6Z"/></svg>
      </button>
      <div class="kizzu-testimonials__grid" id="KizzuTestimonials-{{ section.id }}">
      {% for block in section.blocks %}
        <article class="kizzu-testimonial-card" {{ block.shopify_attributes }}>
          <div class="kizzu-testimonial-card__image">
            {% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.product_name }}{% else %}<div class="kizzu-testimonial-card__placeholder"><svg aria-hidden="true" viewBox="0 0 64 64"><path d="M14 25 32 12l18 13v25H14V25Zm8 4v17h20V29H22Zm5 5h10v7H27v-7Z"/></svg></div>{% endif %}
          </div>
          <div class="kizzu-testimonial-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {% for star in (1..5) %}<svg class="{% if star > block.settings.rating %}is-empty{% endif %}" aria-hidden="true" viewBox="0 0 20 20"><path d="m10 1.8 2.5 5.1 5.6.8-4.1 4 1 5.6-5-2.7-5 2.7 1-5.6-4.1-4 5.6-.8L10 1.8Z"/></svg>{% endfor %}
          </div>
          <blockquote class="kizzu-testimonial-card__quote"><span class="kizzu-testimonial-card__quote-mark">&ldquo;</span><div class="rte">{{ block.settings.description }}</div></blockquote>
          <div class="kizzu-testimonial-card__customer">
            {% if block.settings.avatar != blank %}{{ block.settings.avatar | image_url: width: 150 | image_tag: class: 'kizzu-testimonial-card__avatar', loading: 'lazy', alt: block.settings.customer_name }}{% else %}<span class="kizzu-testimonial-card__avatar-placeholder">{{ block.settings.customer_name | slice: 0 }}</span>{% endif %}
            <div><p class="kizzu-testimonial-card__name">&ndash; {{ block.settings.customer_name }}</p>{% if block.settings.product_name != blank %}<p class="kizzu-testimonial-card__purchase">Purchased: <strong>{{ block.settings.product_name }}</strong></p>{% endif %}{% if block.settings.verified %}<span class="kizzu-testimonial-card__verified"><svg aria-hidden="true" viewBox="0 0 20 20"><path d="M10 1.5a8.5 8.5 0 1 0 0 17 8.5 8.5 0 0 0 0-17Zm-1.2 12.4L5.4 10.5l1.4-1.4 2 2 4.5-4.5 1.4 1.4-6.5 5.9Z"/></svg>Verified Purchase</span>{% endif %}</div>
          </div>
        </article>
      {% endfor %}
      </div>
      <button class="kizzu-testimonials__arrow kizzu-testimonials__arrow--next" type="button" aria-label="Next testimonials">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8.6 16.6 10 18l6-6-6-6-1.4 1.4 4.6 4.6-4.6 4.6Z"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  (() => {
    const initTestimonials = (root = document) => {
      root.querySelectorAll('.kizzu-testimonials').forEach((section) => {
        if (section.dataset.sliderReady === 'true') return;
        const slider = section.querySelector('.kizzu-testimonials__grid');
        const previous = section.querySelector('.kizzu-testimonials__arrow--prev');
        const next = section.querySelector('.kizzu-testimonials__arrow--next');
        if (!slider || !previous || !next) return;

        const slideByCard = (direction) => {
          const card = slider.querySelector('.kizzu-testimonial-card');
          const gap = parseFloat(getComputedStyle(slider).columnGap) || 22;
          slider.scrollBy({ left: direction * ((card ? card.offsetWidth : slider.clientWidth) + gap), behavior: 'smooth' });
        };
        const updateArrows = () => {
          const hasOverflow = slider.scrollWidth > slider.clientWidth + 2;
          previous.hidden = !hasOverflow;
          next.hidden = !hasOverflow;
        };

        previous.addEventListener('click', () => slideByCard(-1));
        next.addEventListener('click', () => slideByCard(1));
        window.addEventListener('resize', updateArrows);
        section.dataset.sliderReady = 'true';
        updateArrows();
      });
    };
    initTestimonials();
    document.addEventListener('shopify:section:load', (event) => initTestimonials(event.target));
  })();
</script>

{% schema %}
{
  "name": "Kizzu Testimonials",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "HAPPY CUSTOMERS" },
    { "type": "text", "id": "heading", "label": "Section title", "default": "Happy Kids," },
    { "type": "text", "id": "heading_highlight", "label": "Title highlight", "default": "Happy Parents" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>See why families love shopping with Kizzu Toys.</p>" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-3" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [{ "type": "testimonial", "name": "Testimonial", "settings": [
    { "type": "image_picker", "id": "image", "label": "Product image" },
    { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
    { "type": "richtext", "id": "description", "label": "Review description", "default": "<p>Excellent quality and a wonderful shopping experience.</p>" },
    { "type": "image_picker", "id": "avatar", "label": "Customer avatar image" },
    { "type": "text", "id": "customer_name", "label": "Customer name", "default": "Customer" },
    { "type": "text", "id": "product_name", "label": "Purchased product name", "default": "Toy" },
    { "type": "checkbox", "id": "verified", "label": "Show verified purchase", "default": true }
  ]}],
  "presets": [{ "name": "Kizzu Testimonials", "blocks": [
    { "type": "testimonial", "settings": { "customer_name": "Priya Sharma", "product_name": "Remote Control Car", "description": "<p>Excellent quality! My son absolutely loves this remote control car. It's sturdy, fast, and the battery lasts longer than expected.</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Riddhi Patel", "product_name": "Kids Supermarket Play Set", "description": "<p>My daughter spends hours playing with this supermarket set. The accessories are colorful and durable.</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Neha Mehta", "product_name": "Wooden Learning Puzzle", "description": "<p>Perfect educational toy! It helped my little one learn shapes and colors while having fun.</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Aarti Shah", "product_name": "Musical Piano Toy", "description": "<p>Amazing sound quality and bright lights. My toddler enjoys playing with it every single day.</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Karan Joshi", "product_name": "Building Blocks Set", "description": "<p>The blocks are easy to assemble and great for improving creativity. Highly recommended for kids.</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Sneha Desai", "product_name": "Doctor Play Kit", "description": "<p>Very realistic accessories! My child loves pretending to be a doctor. Great learning toy.</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Pooja Trivedi", "product_name": "Kitchen Play Set", "description": "<p>Beautiful design with lots of accessories. The quality exceeded my expectations.</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Rahul Verma", "product_name": "Mini Basketball Hoop Set", "description": "<p>Easy to install and perfect for indoor play. Keeps my kids active and entertained.</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Amit Singh", "product_name": "Walking Dinosaur Toy", "description": "<p>The moving dinosaur with lights and sounds is a huge hit in our home. Worth every penny!</p>" } },
    { "type": "testimonial", "settings": { "customer_name": "Kavya Nair", "product_name": "Plush Teddy Bear", "description": "<p>Super soft, adorable, and exactly as shown in the pictures. My daughter sleeps with it every night.</p>" } }
  ]}]
}
{% endschema %}
