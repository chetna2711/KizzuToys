{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

<footer class="kizzu-footer color-{{ section.settings.color_scheme }} gradient">
  <div class="kizzu-footer__inner page-width">
    <div class="kizzu-footer__brand">
      <a href="{{ routes.root_url }}" class="kizzu-footer__logo-link" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_height = section.settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {{
            settings.logo
            | image_url: width: 520
            | image_tag:
              class: 'kizzu-footer__logo',
              loading: 'lazy',
              width: section.settings.logo_width,
              height: logo_height,
              alt: shop.name
          }}
        {%- else -%}
          <span class="kizzu-footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- if section.settings.description != blank -%}
        <div class="kizzu-footer__description rte">
          {{ section.settings.description }}
        </div>
      {%- endif -%}

      {%- render 'social-icons', class: 'kizzu-footer__social' -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <nav class="kizzu-footer__menus" aria-label="Footer">
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_list' -%}
            <div class="kizzu-footer__menu" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2>{{ block.settings.heading }}</h2>
              {%- endif -%}

              {%- if block.settings.menu != blank -%}
                <ul class="list-unstyled">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}">{{ link.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="kizzu-footer__contact">
      <h2>{{ section.settings.contact_heading }}</h2>

      <div class="kizzu-footer__contact-item">
        <span class="kizzu-footer__contact-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false"><path d="M12 2.5a7.2 7.2 0 0 0-7.2 7.2c0 5.2 7.2 11.8 7.2 11.8s7.2-6.6 7.2-11.8A7.2 7.2 0 0 0 12 2.5Zm0 10.2a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"/></svg>
        </span>
        <span>
          <strong>Address</strong>
          <small>{{ section.settings.contact_address }}</small>
        </span>
      </div>

      <div class="kizzu-footer__contact-item">
        <span class="kizzu-footer__contact-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false"><path d="M6.6 3.5 4 4.1C3.3 4.3 2.8 5 3 5.7c1.4 7.1 7.2 12.9 14.3 14.3.7.1 1.4-.3 1.6-1l.6-2.6c.2-.7-.2-1.4-.8-1.7l-3-1.3c-.6-.3-1.2-.1-1.6.4l-1.2 1.5a11.6 11.6 0 0 1-4.2-4.2l1.5-1.2c.5-.4.7-1.1.4-1.6l-1.3-3c-.3-.6-1-.9-1.7-.8Z"/></svg>
        </span>
        <span>
          <strong>Phone / whatsapp</strong>
          <small><a href="tel:{{ section.settings.contact_phone | remove: ' ' }}">{{ section.settings.contact_phone }}</a></small>
        </span>
      </div>

      <div class="kizzu-footer__contact-item">
        <span class="kizzu-footer__contact-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false"><path d="M3 5h18v14H3V5Zm2 2v.5l7 4.4 7-4.4V7H5Zm14 2.7-7 4.4-7-4.4V17h14V9.7Z"/></svg>
        </span>
        <span>
          <strong>Email</strong>
          <small><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></small>
        </span>
      </div>

      <div class="kizzu-footer__contact-item">
        <span class="kizzu-footer__contact-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false"><path d="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Zm0 2a7 7 0 1 1 0 14 7 7 0 0 1 0-14Zm1 2.5h-2V13l4.4 2.6 1-1.7-3.4-2V7.5Z"/></svg>
        </span>
        <span>
          <strong>Business hours</strong>
          <small>{{ section.settings.business_hours }}</small>
        </span>
      </div>
    </div>

    <div class="kizzu-footer__newsletter">
      <div class="kizzu-footer__newsletter-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M3 5h18v14H3V5Zm2 2v.5l7 4.4 7-4.4V7H5Zm14 2.7-7 4.4-7-4.4V17h14V9.7Z"/>
        </svg>
      </div>
      <h2>{{ section.settings.newsletter_heading }}</h2>
      <p>{{ section.settings.newsletter_text }}</p>

      {%- form 'customer', id: 'ContactFooter', class: 'kizzu-footer__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="kizzu-footer__field">
          <input
            id="NewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            placeholder="Enter your email"
            required
          >
          <button type="submit" name="commit" aria-label="{{ 'newsletter.button_label' | t }}">
            <svg aria-hidden="true" viewBox="0 0 20 20" focusable="false">
              <path d="M3 10h11.1l-4.3-4.3L11 4.5l6.5 6.5L11 17.5l-1.2-1.2 4.3-4.3H3v-2Z"/>
            </svg>
          </button>
        </div>

        {%- if form.errors -%}
          <small class="kizzu-footer__message">
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </small>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <small class="kizzu-footer__message kizzu-footer__message--success">
            {{ 'newsletter.success' | t }}
          </small>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>

  <div class="kizzu-footer__bottom page-width">
    <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</small>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "link_list",
      "name": "Footer Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop By Age"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 260,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 180
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Thoughtfully designed toys that inspire learning, creativity and joyful play.</p>"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Stay in the loop"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Sign up for exclusive offers, new launches and parenting tips."
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact Heading",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "contact_address",
      "label": "Address",
      "default": "101, Shivpark , Motavarachha, Surat -394101"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone / WhatsApp",
      "default": "+91 9426862783"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "kizzutoys1@gmail.com"
    },
    {
      "type": "text",
      "id": "business_hours",
      "label": "Business Hours",
      "default": "Monday - Saturday : 10:00 AM - 7:00 PM"
    }
  ]
}
{% endschema %}
