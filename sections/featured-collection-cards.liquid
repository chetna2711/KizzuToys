{{ 'featured-collection-cards.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.section_color_scheme }}">
  <div class="page-width featured-collection-cards__wrap">
    {% if section.settings.heading != blank or section.settings.badge_text != blank %}
      <div class="featured-collection-cards__header">
        {% if section.settings.badge_text != blank %}
          <div class="featured-collection-cards__badge">
            <span class="badge badge--{{ section.settings.badge_style }}">
              <svg aria-hidden="true" viewBox="0 0 20 20">
                <path d="M10 17.5 8.7 16.3C4.3 12.3 1.5 9.8 1.5 6.7 1.5 4.2 3.5 2.2 6 2.2c1.4 0 2.8.7 3.7 1.8.9-1.1 2.3-1.8 3.7-1.8 2.5 0 4.6 2 4.6 4.5 0 3.1-2.8 5.6-7.2 9.6L10 17.5Z"/>
              </svg>
              <span>{{ section.settings.badge_text }}</span>
            </span>
          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="featured-collection-cards__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="featured-collection-cards__description rte">
            <p>{{ section.settings.description }}</p>
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="featured-collection-cards__grid">
        {% for block in section.blocks %}
          <div class="featured-collection-card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <div class="featured-collection-card__image">
                {{ block.settings.image | image_url: width: 500 | image_tag: alt: block.settings.title }}
              </div>
            {% else %}
              <div class="featured-collection-card__image featured-collection-card__image--placeholder">
                <span>{{ block.settings.title | default: 'Toys' | truncate: 2, '' }}</span>
              </div>
            {% endif %}

            <div class="featured-collection-card__content">
              {% if block.settings.title != blank %}
                <h3 class="featured-collection-card__title">
                  {{ block.settings.title }}
                </h3>
              {% endif %}

              {% if block.settings.button_label != blank %}
                <a 
                  {% if block.settings.button_url == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_url }}"
                  {% endif %}
                  class="button button--primary featured-collection-card__button"
                >
                  {{ block.settings.button_label }}
                  <span aria-hidden="true">&rarr;</span>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Featured Collection Cards",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "SHOP BY CATEGORY"
    },
    {
      "type": "select",
      "id": "badge_style",
      "label": "Badge Style",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "accent",
          "label": "Accent"
        }
      ],
      "default": "primary"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        {
          "value": "h1",
          "label": "H1 (Extra Large)"
        },
        {
          "value": "h2",
          "label": "H2 (Large)"
        },
        {
          "value": "h3",
          "label": "H3 (Medium)"
        },
        {
          "value": "h4",
          "label": "H4 (Small)"
        }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Explore our wide range of toys designed to educate, engage and inspire.</p>"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Color Scheme",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Cards",
